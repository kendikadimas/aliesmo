# Backend API URL (Laravel)
# Untuk local dev, gunakan URL Laravel Anda
VITE_API_URL=http://aliesmo.test/api/v1

# Untuk production, ganti dengan URL backend yang sudah di-deploy:
# VITE_API_URL=https://your-backend.com/api/v1

# Midtrans Client Key (WAJIB untuk payment popup)
# Dapatkan di: https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# Sandbox (testing): diawali dengan "SB-Mid-client-..."
# Production: diawali dengan "Mid-client-..."
VITE_MIDTRANS_CLIENT_KEY=

# Set ke 'true' jika sudah production
VITE_MIDTRANS_IS_PRODUCTION=false
