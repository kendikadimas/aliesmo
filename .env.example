# Aliesmo - E-Commerce Kemeja
# Copy file ini ke .env dan sesuaikan dengan environment
# cp .env.example .env

APP_NAME=Aliesmo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aliesmo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@aliesmo.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# WhatsApp
WHATSAPP_NUMBER=6285196811722

# Sanctum (untuk SPA auth, isi dengan domain frontend)
SANCTUM_STATEFUL_DOMAINS=localhost

# RajaOngkir (cek ongkir)
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://api.rajaongkir.com/starter

VITE_APP_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════
# PRODUCTION CHECKLIST — sebelum ubah APP_ENV ke production:
# 1. APP_DEBUG=false
# 2. APP_KEY= (generate dengan php artisan key:generate)
# 3. APP_URL=https://domain-anda.com
# 4. DB_PASSWORD= (password kuat)
# 5. SESSION_SECURE_COOKIE=true
# 6. SANCTUM_STATEFUL_DOMAINS=domain-anda.com
# 7. LOG_LEVEL=warning
# 8. MIDTRANS_IS_PRODUCTION=true
# 9. MAIL_MAILER=smtp (atau ses/postmark)
# 10. QUEUE_CONNECTION=database (pastikan worker jalan)
# 11. npm run build (build frontend assets)
# 12. php artisan storage:link
# ═══════════════════════════════════════════════════
